{
  "name": "afaia-maps-frontend",
  "version": "1.0.0",
  "description": "Afaia Maps PWA + Capacitor (Android/iOS)",
  "private": true,
  "scripts": {
    "dev":           "npx serve frontend -p 5173 --no-clipboard",
    "build":         "node scripts/build.js",
    "build:prod":    "node scripts/build.js --prod",
    "cap:init":      "npx cap init 'Afaia Maps' com.afaiamaps.app --web-dir frontend",
    "cap:add:android":"npx cap add android",
    "cap:add:ios":   "npx cap add ios",
    "cap:sync":      "npx cap sync",
    "cap:copy":      "npx cap copy",
    "cap:open:android":"npx cap open android",
    "cap:open:ios":  "npx cap open ios",
    "android":       "npm run cap:sync && npx cap open android",
    "ios":           "npm run cap:sync && npx cap open ios",
    "icons":         "npx capacitor-assets generate",
    "lint:html":     "npx htmlhint frontend/**/*.html",
    "preview":       "npx serve frontend -p 5173"
  },
  "dependencies": {
    "@capacitor/android":            "^6.0.0",
    "@capacitor/app":                "^6.0.0",
    "@capacitor/camera":             "^6.0.0",
    "@capacitor/core":               "^6.0.0",
    "@capacitor/filesystem":         "^6.0.0",
    "@capacitor/geolocation":        "^6.0.0",
    "@capacitor/haptics":            "^6.0.0",
    "@capacitor/ios":                "^6.0.0",
    "@capacitor/keyboard":           "^6.0.0",
    "@capacitor/local-notifications":"^6.0.0",
    "@capacitor/network":            "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/screen-orientation": "^6.0.0",
    "@capacitor/share":              "^6.0.0",
    "@capacitor/splash-screen":      "^6.0.0",
    "@capacitor/status-bar":         "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli":    "^6.0.0",
    "capacitor-assets": "^3.0.0",
    "serve":            "^14.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["maps", "gps", "offline", "pwa", "capacitor"],
  "author": "Afaia Maps",
  "license": "UNLICENSED"
}
